    onion (* <= nrel_main_idtf: [лук] (* <- lang_ru;; *);; *);
    sugar (* <= nrel_main_idtf: [сахар] (* <- lang_ru;; *);; *);
    carrot (* <= nrel_main_idtf: [морковка] (* <- lang_ru;; *);; *);
    vegetable_oil (* <= nrel_main_idtf: [растительное масло] (* <- lang_ru;; *);; *);
    flour (* <= nrel_main_idtf: [мука] (* <- lang_ru;; *);; *);
    butter (* <= nrel_main_idtf: [сливочное масло] (* <- lang_ru;; *);; *);
    milk (* <= nrel_main_idtf: [молоко] (* <- lang_ru;; *);; *);
    rice (* <= nrel_main_idtf: [рис] (* <- lang_ru;; *);; *);
    garlic (* <= nrel_main_idtf: [чеснок] (* <- lang_ru;; *);; *);
    cucumber (* <= nrel_main_idtf: [огурец] (* <- lang_ru;; *);; *);
    tomato (* <= nrel_main_idtf: [помидор] (* <- lang_ru;; *);; *);
    buckwheat (* <= nrel_main_idtf: [гречка] (* <- lang_ru;; *);; *);
    cabbage (* <= nrel_main_idtf: [капуста] (* <- lang_ru;; *);; *);
    bread (* <= nrel_main_idtf: [хлеб] (* <- lang_ru;; *);; *);
    cheese (* <= nrel_main_idtf: [сыр] (* <- lang_ru;; *);; *);
