    macarones (* <= nrel_main_idtf: [макароны] (* <- lang_ru;; *);; *);
    sour_cream (* <= nrel_main_idtf: [сметана] (* <- lang_ru;; *);; *);
    ground_beef (* <= nrel_main_idtf: [фарш] (* <- lang_ru;; *);; *);

=> nrel_note:
    [Ингредиент — это составная часть блюда, используемая для приготовления пищи.
    Может быть как натуральным продуктом, так и добавкой. ]
	(* <- lang_ru;; *);;

nrel_amount
=> nrel_first_domain:
    concept_ingredient;
<= nrel_second_domain:
    nrel_type_of_unit;;