    <- sc_node_class;
    => nrel_main_idtf: [грибы]     (* <- lang_ru;; *);
    => nrel_main_idtf: [mushrooms] (* <- lang_en;; *);
    <= nrel_inclusion: food;;

mushrooms        <- mushrooms_class; => nrel_main_idtf: [грибы (общее)]    (* <- lang_ru;; *);;
