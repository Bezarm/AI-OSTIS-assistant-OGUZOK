/* ==========================================================================
   БАЗА ЗНАНИЙ: ПРОДУКТЫ ПИТАНИЯ
   ==========================================================================
   SCs-онтология продуктов питания.
   Иерархия строится через nrel_inclusion (включение классов).
   Конкретные продукты — экземпляры классов через дугу принадлежности <-.
   ========================================================================== */


/* ==========================================================================
   РАЗДЕЛ 1. ОТНОШЕНИЯ
   ========================================================================== */

nrel_used_in
    <- sc_node_non_role_relation;
    => nrel_main_idtf: [используется в*] (* <- lang_ru;; *);
    => nrel_main_idtf: [used in*]         (* <- lang_en;; *);;

nrel_inclusion
    <- sc_node_non_role_relation;
    => nrel_main_idtf: [включение*] (* <- lang_ru;; *);
    => nrel_main_idtf: [inclusion*]  (* <- lang_en;; *);;


/* ==========================================================================
   РАЗДЕЛ 2. КОРНЕВОЙ КЛАСС И ВЕРХНЕУРОВНЕВЫЕ ПОДКЛАССЫ
   ========================================================================== */

food
    <- sc_node_class;
    => nrel_main_idtf: [продукт питания] (* <- lang_ru;; *);
    => nrel_main_idtf: [food]             (* <- lang_en;; *);;

plant_food
    <- sc_node_class;
    => nrel_main_idtf: [растительная пища] (* <- lang_ru;; *);
    => nrel_main_idtf: [plant food]         (* <- lang_en;; *);
    <= nrel_inclusion: food;;

animal_food
    <- sc_node_class;
    => nrel_main_idtf: [животная пища] (* <- lang_ru;; *);
    => nrel_main_idtf: [animal food]    (* <- lang_en;; *);
    <= nrel_inclusion: food;;

processed_food
    <- sc_node_class;
    => nrel_main_idtf: [переработанные продукты] (* <- lang_ru;; *);
    => nrel_main_idtf: [processed food]           (* <- lang_en;; *);
    <= nrel_inclusion: food;;


/* ==========================================================================
   РАЗДЕЛ 3. КАТЕГОРИИ РАСТИТЕЛЬНОЙ ПИЩИ
   ========================================================================== */

