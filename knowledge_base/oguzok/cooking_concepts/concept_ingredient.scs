concept_ingredient

<- sc_node_class;

=> nrel_main_idtf:
	[ингредиент]
	(* <- lang_ru;; *);
    [ingredient]
	(* <- lang_en;; *);

=> nrel_inclusion:
    concept_food;
    eggs (* <= nrel_main_idtf: [яйцо] (* <- lang_ru;; *);; *);
