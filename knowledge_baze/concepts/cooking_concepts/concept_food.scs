concept_food

<- sc_node_class;

=> nrel_main_idtf:
	[еда]
	(* <- lang_ru;; *);
    [food]
	(* <- lang_en;; *);

=> nrel_inclusion:
    concept_meal;
    
=> nrel_note:
    [Пища (еда) — то, что едят, чем питаются;
    любое вещество, пригодное для еды и питья живым организмам для пополнения запасов энергии и необходимых составляющих для нормального течения химических реакций обмена веществ:
    белков, жиров, углеводов, витаминов, минералов и микроэлементов. ]
	(* <- lang_ru;; *);;